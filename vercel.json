    { "source": "/canal-do-texter/modalidades-de-transcricao-de-audio/", "destination": "/transcricao-de-audio", "permanent": true },
    { "source": "/modelos-de-transcricao-de-audio-em-texto/", "destination": "/transcricao-de-audio", "permanent": true },
    { "source": "/modelos-de-transcricao-de-audio-em-texto", "destination": "/transcricao-de-audio", "permanent": true },
    { "source": "/softwares-de-transcricao-de-audio/", "destination": "/transcricao-de-audio", "permanent": true },
    { "source": "/softwares-de-transcricao-de-audio", "destination": "/transcricao-de-audio", "permanent": true },
    { "source": "/transcricao-de-audio-em-texto/", "destination": "/transcricao-de-audio", "permanent": true },
    { "source": "/transcricao-de-audio-para-texto/", "destination": "/transcricao-de-audio", "permanent": true },
    { "source": "/transcricao-de-audio-por-voz/", "destination": "/transcricao-de-audio", "permanent": true },
    { "source": "/transcricao-de-audio/transcricao-automatica/", "destination": "/transcricao-automatica", "permanent": true },
    { "source": "/transcricao-automatica-2/", "destination": "/transcricao-automatica", "permanent": true },
    { "source": "/servicos/transcricao-empresarial/", "destination": "/transcricao-de-audio", "permanent": true },
    { "source": "/servicos/transcricao-academica/", "destination": "/transcricao-de-audio", "permanent": true },

    { "source": "/dicas-gravar-audio-celular-com-qualidade/", "destination": "/", "permanent": true },
    { "source": "/dicas-gravar-audio-celular-com-qualidade", "destination": "/", "permanent": true },
    { "source": "/melhores-apps-gravacao-audio-celular/", "destination": "/", "permanent": true },
