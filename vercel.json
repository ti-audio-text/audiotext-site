    { "source": "/legendagem-filmes-propagandas-videos-youtube/", "destination": "/legendagem", "permanent": true },
    { "source": "/legendagem-video-aulas-treinamentos-palestras/", "destination": "/legendagem", "permanent": true },
    { "source": "/legendagem-video-aulas-treinamentos-palestras", "destination": "/legendagem", "permanent": true },

    { "source": "/__trashed/", "destination": "/", "permanent": true },
    { "source": "/lava-jato-case-de-sucesso-audiotext/", "destination": "/sobre", "permanent": true },
    { "source": "/contato/", "destination": "/", "permanent": true },
    { "source": "/como-funciona/", "destination": "/", "permanent": true },
    { "source": "/como-funciona/:path*", "destination": "/", "permanent": true },
    { "source": "/envio", "destination": "/", "permanent": true },
    { "source": "/equipe/", "destination": "/sobre", "permanent": true },
    { "source": "/category/:path*", "destination": "/", "permanent": true },
    { "source": "/tag/:path*", "destination": "/", "permanent": true },
    { "source": "/canal-do-texter/", "destination": "/", "permanent": true },
    { "source": "/author/:path*", "destination": "/sobre", "permanent": true },
    { "source": "/endereco/:path*", "destination": "/sobre", "permanent": true },
    { "source": "/categoria-Equipe/:path*", "destination": "/sobre", "permanent": true },
    { "source": "/categoria-Faq/:path*", "destination": "/", "permanent": true },
    { "source": "/pergunta-frequentes/:path*", "destination": "/", "permanent": true },
    { "source": "/porque-confiar-na-audiotext/:path*", "destination": "/sobre", "permanent": true },
    { "source": "/valores-agencias/:path*", "destination": "/", "permanent": true },
    { "source": "/canal-do-texter/:path*", "destination": "/transcricao-de-audio", "permanent": true },
    { "source": "/texter/", "destination": "/selecao-temp", "permanent": true },
    { "source": "/texter", "destination": "/selecao-temp", "permanent": true }
  ]
}
